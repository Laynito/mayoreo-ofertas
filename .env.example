APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Colas: database para que rastreo:tienda termine rápido y el worker envíe a Telegram
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Telegram (notificaciones Free / Premium)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=              # Solo se usa si FREE y PREMIUM están vacíos (un solo canal)
# IMPORTANTE: FREE y PREMIUM deben estar los dos definidos. Si PREMIUM está vacío, las ofertas
# de alto % no se envían a ningún lado (no se usa CHAT_ID como sustituto para no mandar al Gratis).
TELEGRAM_CHAT_ID_FREE=-1003815235125      # Canal Gratis (ofertas 10–29.9% bajada; teasers de bombas)
TELEGRAM_CHAT_ID_PREMIUM=-1003708044071   # Canal Premium (ofertas ≥30%, <10% y con captura)
# TELEGRAM_PREMIUM_JOIN_URL=     # URL de aterrizaje para suscriptores (ej: https://t.me/TuCanalPremium_o_PaginaDePago)
# TELEGRAM_MAX_OFERTAS_POR_RASTREO=10     # Límite de ofertas por tienda al canal Gratis (0 = sin límite). Premium recibe todas.
# TELEGRAM_DELAY_ENTRE_OFERTAS=15        # Segundos entre cada oferta encolada (envío poco a poco; reduce timeouts). Recomendado 15–30.
# TELEGRAM_DELAY_INICIAL_OFERTAS=10     # Segundos antes de la 1ª oferta (evita que la primera captura falle por Chromium en frío).

# Elektra (VTEX): código postal para cookie de localización y precios
ELEKTRA_CODIGO_POSTAL=01210

# Browsershot: ruta a Chromium del sistema para capturas de ofertas (opcional).
# Si las capturas fallan con "Could not find Chrome", instala: apt install chromium
# y descomenta la línea con la ruta que devuelva: which chromium
# BROWSERSHOT_CHROME_PATH=/usr/bin/chromium

# Proxy global para rastreo (opcional). Vacío = tráfico directo; si una tienda bloquea, pon aquí la URL del proxy.
# Ejemplo: http://usuario:contraseña@proxy.ejemplo.com:8080
PROXY_URL=

# Mercado Libre – integración oficial OAuth (evita 403 en API de ofertas)
# Crear app en https://developers.mercadolibre.com.mx; redirect_uri = https://tu-dominio/mercado-libre/callback
# En la app, activar scope offline_access para recibir refresh_token (sin él el access_token caduca en horas).
# ML_APP_ID=
# ML_SECRET_KEY=
# ML_REDIRECT_URI=https://mayoreo.cloud/mercado-libre/callback
# ML_AFFILIATE_ID=   # Opcional: ID de afiliado para enlaces con comisión (matt_tool). Ver afiliados.mercadolibre.com.mx

# Admitad: código de verificación del sitio (meta verify-admitad en la página de inicio)
ADMITAD_VERIFICATION_CODE=

# Admitad API (generación de deeplinks oficiales). Panel Admitad → Credenciales.
ADMITAD_CLIENT_ID=
ADMITAD_CLIENT_SECRET=
# Base64 de "CLIENT_ID:CLIENT_SECRET" para Basic Auth (ej: echo -n "id:secret" | base64)
ADMITAD_BASE64_HEADER=
# IDs para endpoint deeplink (espacio publicitario y campaña/programa de afiliados)
ADMITAD_WEBSITE_ID=
ADMITAD_CAMPAIGN_ID=
