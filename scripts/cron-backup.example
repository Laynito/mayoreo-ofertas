# Cron para copias de seguridad diarias de Mayoreo Cloud
# Instalar: crontab -e  y pegar la línea siguiente (ajusta el usuario si no es mayoreo).

# Backup todos los días a las 02:00
0 2 * * * /bin/bash /home/mayoreo/htdocs/mayoreo-cloud/scripts/backup.sh >> /home/mayoreo/htdocs/mayoreo-cloud/storage/logs/backup.log 2>&1

# Opcional: backup cada 12 horas (00:00 y 12:00)
# 0 0,12 * * * /bin/bash /home/mayoreo/htdocs/mayoreo-cloud/scripts/backup.sh >> /home/mayoreo/htdocs/mayoreo-cloud/storage/logs/backup.log 2>&1

# Opcional: backup cada 6 horas
# 0 */6 * * * /bin/bash /home/mayoreo/htdocs/mayoreo-cloud/scripts/backup.sh >> /home/mayoreo/htdocs/mayoreo-cloud/storage/logs/backup.log 2>&1
